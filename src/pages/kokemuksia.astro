---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import Button from '../components/ui/Button.astro';

const testimonials = [
  { name: 'Maria K.', service: 'Yksilövalmennus', quote: 'Ilona on ihana valmentaja! Treenit ovat monipuolisia ja kannustava ote motivoi jatkamaan. Olen saavuttanut tavoitteeni nopeammin kuin uskoin. Suosittelen lämpimästi!', rating: 5 },
  { name: 'Sanna L.', service: 'Ulkotreenit', quote: 'Ulkotreenit Ilona kanssa ovat paras päätös mitä olen tehnyt. Treeni on tehokasta ja hauskaa samaan aikaan. Turkulainen luonto vielä bonuksena!', rating: 5 },
  { name: 'Tiimi Yritys Oy', service: 'Yrityspalvelut', quote: 'Tilatimme tyky-päivän IloFitiltä ja se ylitti odotuksemme. Ilona huomioi eri kuntotasot ja kaikki lähtivät kotiin hyvällä mielellä. Tullaan tilaamaan uudelleen!', rating: 5 },
  { name: '[PLACEHOLDER: Asiakkaan nimi]', service: 'Pienryhmävalmennus', quote: '[PLACEHOLDER: Ilona kerää lisää asiakaskokemuksia tähän.]', rating: 5 },
];
const starSvg = `<svg width="14" height="14" viewBox="0 0 24 24" fill="#E8A0B0" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
---

<PageLayout title="Asiakaskokemuksia | IloFit — Personal Trainer Turku" description="Lue IloFitin asiakkaiden kokemuksia. Personal trainer palvelut Turussa — mitä asiakkaat sanovat.">

  <!-- Hero -->
  <section class="bg-off-white pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">IloFit</p>
      <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">Asiakaskokemuksia</h1>
      <p class="text-xl text-charcoal-mid max-w-xl">Mitä asiakkaat sanovat valmennuksesta. Lue omakohtaisia kokemuksia yksilövalmennuksesta, pienryhmistä ja yrityspalveluista.</p>
    </div>
  </section>

  <!-- Google reviews placeholder -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-soft-border bg-off-white p-8 text-center">
        <div class="flex justify-center gap-1 mb-3">
          {[...Array(5)].map(() => <Fragment set:html={starSvg} />)}
        </div>
        <p class="font-display text-3xl font-semibold text-charcoal mb-2">5.0</p>
        <p class="text-charcoal-mid text-sm mb-6">[PLACEHOLDER: Google-arvostelu-widget (Trustindex tai vastaava) upotettuna tähän]</p>
        <a href="https://g.page/r/ilofit/review" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 rounded-lg border border-soft-border bg-white px-6 py-3 text-sm font-medium text-charcoal hover:border-pink hover:text-pink transition-colors">
          Jätä arvostelu Googlessa →
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials grid -->
  <section class="bg-white py-16 pb-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mb-12">
        <SectionHeader eyebrow="Kokemuksia" heading="Asiakkaiden sanoin" />
      </div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2">
        {testimonials.map((t) => (
          <div class="rounded-xl border border-soft-border bg-off-white p-8 shadow-warm">
            <div class="flex gap-0.5 mb-4">
              {[...Array(t.rating)].map(() => <Fragment set:html={starSvg} />)}
            </div>
            <blockquote class="text-charcoal-mid leading-relaxed mb-6 italic">&ldquo;{t.quote}&rdquo;</blockquote>
            <div class="flex items-center gap-3">
              <div class="w-10 h-10 rounded-full bg-pink-light flex items-center justify-center">
                <span class="font-display text-sm font-semibold text-pink">{t.name.charAt(0)}</span>
              </div>
              <div>
                <p class="font-medium text-charcoal text-sm">{t.name}</p>
                <p class="text-xs text-pink">{t.service}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-pink-light py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader eyebrow="Aloitetaan" heading="Haluatko oman muutostarinasi?" centered class="mb-6" />
      <p class="text-charcoal-mid mb-8">Varaa maksuton alkukartoitus ja aloitetaan yhdessä.</p>
      <Button href="/yhteystiedot" size="lg">Varaa ilmainen konsultaatio</Button>
    </div>
  </section>

</PageLayout>
