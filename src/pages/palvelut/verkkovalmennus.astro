---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';

const included = ['Aloituspalaveri etänä','Sinulle räätälöidyt harjoitusohjelmat (kuntosalille tai kotiin)','Säännölliset etätapaamiset (valittu määrä kuukaudessa)','Ohjelmien päivitys tarpeen mukaan','Ravinto-ohjelman runko','Yhteydenpito, viikkoraportointi ja seuranta sovelluksen kautta','Valmentajan chat-tuki koko valmennuksen ajan'];
const goals = [{title:'Painonpudotus',desc:'Tehokas ja kestävä painonpudotus oikean harjoittelun ja ravinto-ohjauksen avulla. Ei pikadieettejä — pysyviä elämäntapamuutoksia.'},{title:'Kiinteytyminen',desc:'Kiinteä ja tukeva keho kehon koostumusta parantamalla. Yhdistetään sopiva lihastyö ja sopiva cardio.'},{title:'Lihasmassan kasvatus',desc:'Progressiivinen harjoittelu, joka rakentaa lihasta tehokkaasti ja turvallisesti.'},{title:'Elämäntapamuutos',desc:'Liikunnasta pysyvä osa arkeasi. Löydät liikunnan ilon ja rakennat terveet, kestävät tottumukset.'}];
const steps = [{n:'01',title:'Ilmainen alkukartoitus',desc:'Käymme läpi tavoitteesi, treenisi historian ja nykyisen tilanteesi. Sitoumukseton ja maksuton.'},{n:'02',title:'Henkilökohtainen ohjelma',desc:'Suunnittelen sinulle räätälöidyn harjoitusohjelman, joka vastaa juuri sinun tavoitteitasi ja aikatauluasi.'},{n:'03',title:'Valmennus & tulosten seuranta',desc:'Treenikerroilla ohjaan sinut liikkeiden läpi, seuraan edistymistäsi ja päivitän ohjelmaa tarpeen mukaan.'}];
const faqs = [{q:'Sopiiko yksilövalmennus aloittelijalle?',a:'Kyllä! Yksilövalmennus on erityisen sopiva aloittelijoille, koska saat henkilökohtaisen ohjauksen ja turvallisen startin liikuntaan.'},{q:'Kuinka usein pitäisi treenata?',a:'Se riippuu tavoitteistasi ja aikataulustasi. Yleensä 2–3 kertaa viikossa on hyvä aloituspiste.'},{q:'Mitä tarvitsen mukaan ensimmäiselle kerralle?',a:'Liikuntavaatteet, juomapullo ja avoimen mielen. Kaikki muu järjestyy!'},{q:'Missä treenit tapahtuvat?',a:'Treenipaikkoja ovat Turku-alueen kuntosalit ja ulkotiloissa Urheilupuisto. Voidaan sopia yhteisesti sopivasta paikasta.'}];
const checkSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
const monthly_prices = [
  { label: '60 min etävalmennus kerran kuukaudessa', price: '60 €/kk' },
  { label: '60 min etävalmennus 2 kertaa kuukaudessa', price: '110 €/kk' },
  { label: '60 min etävalmennus 4 kertaa kuukaudessa', price: '210 €/kk' },
];
---

<PageLayout title="Verkkovalmennus | IloFit — Personal Trainer" description="Henkilökohtainen verkkovalmennus. Räätälöity etävalmennus treeniohjelmalla ja jatkuvalla tuella. Varaa ilmainen alkukartoitus.">

<section class="bg-off-white pt-36 pb-20">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <!-- Vasen: tekstit + nappi -->
      <div>
        <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">
          Palvelut
        </p>
        <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">
          Verkkovalmennus
        </h1>
        <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">Sinun tavoitteesi on minun tavoitteeni!</p> 
        <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">Olipa kyseessä sitten painonpudotus, kiinteytys, lihasvoiman kasvatus tai yleinen terveyden edistys, teemme suunnitelman tavoitteen saavuttamiseksi ja olen tukenasi koko valmennuksen ajan.</p>  
        </p>

        <div class="flex flex-col items-start gap-3">
          <Button href="/yhteystiedot" size="lg">
            Varaa ilmainen konsultaatio
          </Button>
        </div>
      </div>

      <!-- Oikea: kuva -->
      <div class="relative">
<div class="w-full h-[420px] rounded-3xl overflow-hidden shadow-warm">
     <img
       src="/images/remote_training.webp"
       alt="Verkkovalmennus – IloFit"
       class="w-full h-full object-cover object-top grayscale"
     />
   </div>
      </div>
    </div>
  </div>
</section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="rounded-2xl border border-soft-border bg-off-white p-8">
                  <SectionHeader heading="Hinnat" class="mb-8" />

          <div class="mb-6 rounded-xl border border-pink/30 p-4">
            <p class="text-charcoal-mid text-sm mb-2">Huom: myös liikuntaedut käyvät!</p>
            <div class="mt-2 flex flex-wrap gap-2">
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Smartum</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">E-passi</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Edenred</span>
            </div>
          </div>

         <p class="text-charcoal-mid text-lg font-semibold mb-6">Kuukausisopimukset</p>
         <p class="text-charcoal-mid text-sm mb-6">Minimi 3 kuukautta. Hinnat toistaiseksi voimassa 1kk irtisanomisajalla.</p>
          <div class="space-y-4">
            {monthly_prices.map((pkg) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{pkg.label}</span>
                <span class="text-pink font-semibold">{pkg.price}</span>
              </div>
            ))}
          <p class="mb-6"></p>
          <div class="mt-8"><Button href="/yhteystiedot" class="w-full justify-center">Kysy lisää tai varaa aika</Button></div>
        </div>
      </div>

        <div class="rounded-2xl border border-soft-border bg-white p-8">
          <SectionHeader heading="Palvelun sisältö" class="mb-8" />
          <ul class="space-y-4">
            {included.map((item) => (
              <li class="flex items-start gap-3"><Fragment set:html={checkSvg} /><span class="text-charcoal-mid">{item}</span></li>
            ))}
          </ul>
        </div>


    </div>
  </section>




  <section class="bg-white py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader eyebrow="Aloitetaan" heading="Valmis aloittamaan?" centered class="mb-6" />
      <p class="text-charcoal-mid mb-8">Ilmainen alkukartoitus on maksuton ja sitoumukseton. Otetaan ensimmäinen askel yhdessä.</p>
      <Button href="/yhteystiedot" size="lg">Varaa ilmainen konsultaatio</Button>
    </div>
  </section>

</PageLayout>
