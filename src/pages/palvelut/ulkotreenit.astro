---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';

const locations = [{name:'Urheilupuisto — Paavo Nurmi -stadion',desc:'Monipuoliset ulkoliikuntamahdollisuudet Turun sydämessä. Juoksurata, leikkivälineitä ja avoimia nurmikenttiä.'},{name:'Syvälahden koulu / Hirvensalo',desc:'Luonnonkaunis ympäristö vesistön lähellä. Rauhalliset reitit ja upeat maisemat treenitaustaksi.'}];
const whatToBring = ['Sopivat liikuntajalkineet (juoksutossut tai crossfit-kengät)','Säälle sopivat liikuntavaatteet','Juomapullo','Pyyhe','Hyvä asenne!'];
const checkSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
---

<PageLayout title="Ulkotreenit Turku | IloFit — Personal Trainer" description="Ulkoliikuntaa Turussa ammattivalmentajan ohjauksessa. Toiminnallinen harjoittelu Urheilupuistossa ja Hirvensalossa.">

  <!-- Hero with image -->
  <section class="relative min-h-[60vh] flex items-end overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/Image by Geert Pieters.avif" alt="Ulkotreeni Turku — IloFit" class="w-full h-full object-cover object-center" />
      <div class="absolute inset-0 bg-charcoal/60"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 to-transparent"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full pb-20 pt-36">
      <nav class="flex items-center gap-2 text-xs text-white/60 mb-6">
        <a href="/palvelut" class="hover:text-white transition-colors">Palvelut</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-white">Ulkotreenit</span>
      </nav>
      <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">Palvelut</p>
      <h1 class="font-display text-5xl font-semibold text-white sm:text-6xl mb-6">Ulkotreenit</h1>
      <p class="text-xl text-white/80 max-w-xl leading-relaxed mb-10">Toiminnallinen treeni raittiissa ilmassa. Luonto on paras sali — hyvässä seurassa.</p>
      <Button href="/yhteystiedot" size="lg">Varaa paikka</Button>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <SectionHeader eyebrow="Ulkotreeni" heading="Treeniä ulkona, ympäri vuoden" class="mb-6" />
          <div class="space-y-4 text-charcoal-mid leading-relaxed">
            <p>Ulkotreeni on monipuolinen ja tehokas tapa harjoitella. Kehonpainoliikkeet, toiminnallinen harjoittelu ja luovuus ovat kulmakiviä.</p>
            <p>Treenit sopivat kaikille kuntotasoille — jokainen tekee omaan tahtiinsa, mutta yhdessä.</p>
            <p>[PLACEHOLDER: Ilona täyttää aikataulun ja ryhmätietoja]</p>
          </div>
        </div>
        <div class="rounded-2xl bg-off-white border border-soft-border p-8">
          <h3 class="font-display text-2xl font-semibold text-charcoal mb-6">Mitä ottaa mukaan?</h3>
          <ul class="space-y-3">
            {whatToBring.map((item) => (<li class="flex items-start gap-3"><Fragment set:html={checkSvg} /><span class="text-sm text-charcoal-mid">{item}</span></li>))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-off-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16"><SectionHeader eyebrow="Sijainnit" heading="Missä treenataan?" centered /></div>
      <div class="grid grid-cols-1 gap-6 md:grid-cols-2 max-w-3xl mx-auto">
        {locations.map((loc) => (
          <div class="card-accent rounded-xl border border-soft-border bg-white p-6 shadow-warm">
            <div class="flex items-start gap-3 mb-3">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <h3 class="font-display text-lg font-semibold text-charcoal">{loc.name}</h3>
            </div>
            <p class="text-sm text-charcoal-mid leading-relaxed pl-7">{loc.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader eyebrow="Aikataulu" heading="Aikataulu & hinnat" centered class="mb-8" />
      <div class="rounded-2xl bg-off-white border border-soft-border p-8 text-left mb-8">
        <p class="text-charcoal-mid">[PLACEHOLDER: Ilona täyttää viikoittaiset treenitunnit, sijainnit ja hinnat]</p>
      </div>
      <Button href="/yhteystiedot" size="lg">Kysy aikataulusta</Button>
    </div>
  </section>

</PageLayout>
