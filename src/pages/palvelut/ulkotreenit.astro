---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('palvelut', 'ulkotreenit');
const c = entry.data;
---

<PageLayout title="Ulkotreenit Turku | IloFit — Personal Trainer" description="Ulkoliikuntaa Turussa ammattivalmentajan ohjauksessa. Toiminnallinen harjoittelu Urheilupuistossa ja Hirvensalossa.">

  <section class="bg-off-white pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">{c.hero_eyebrow}</p>
          <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">{c.hero_heading}</h1>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">{c.hero_text}</p>
          <Button href="/yhteystiedot" size="lg">{c.hero_cta}</Button>
        </div>
        <div class="relative">
          <div class="w-full h-[420px] rounded-3xl overflow-hidden shadow-warm">
            <img src={c.hero_image} alt="Ulkotreenit Turussa – IloFit" class="w-full h-full object-cover object-center grayscale" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="rounded-2xl border border-soft-border bg-off-white p-8">
          <SectionHeader heading={c.schedule_heading} class="mb-8" />
          <p class="text-charcoal-mid text-sm mb-3">{c.schedule_text1}</p>
          <p class="text-charcoal-mid text-sm mb-6">{c.schedule_text2}</p>
          <div class="space-y-4">
            {c.prices.map((pkg) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{pkg.label}</span>
                <span class="text-pink font-semibold">{pkg.price}</span>
              </div>
            ))}
          </div>
          <p class="mb-6"></p>
          <div class="rounded-xl border border-pink/30 p-4">
            <p class="text-charcoal-mid text-sm mb-2">Huom: myös liikuntaedut käyvät!</p>
            <div class="mt-2 flex flex-wrap gap-2">
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Smartum</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">E-passi</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Edenred</span>
            </div>
          </div>
          <div class="mt-8">
            <Button href="/yhteystiedot" class="w-full justify-center">Kysy lisää tai varaa aika</Button>
          </div>
        </div>

        <div class="rounded-2xl border border-soft-border bg-white p-8">
          <SectionHeader heading={c.info_heading} class="mb-8" />
          <div class="space-y-4 text-charcoal-mid leading-relaxed">
            <p>{c.info_text1}</p>
            <p>{c.info_text2}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
