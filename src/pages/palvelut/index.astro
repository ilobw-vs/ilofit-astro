---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import CtaBanner from '../../components/sections/CtaBanner.astro';

const services = [
  { href: '/palvelut/yksilovalmennus', title: 'Yksilövalmennus', description: 'Henkilökohtainen valmennus räätälöidyllä ohjelmalla. Täydellinen kaikille tavoitteille painonpudotuksesta lihasmassan kasvuun.', keywords: ['Painonpudotus', 'Kiinteytyminen', 'Elämäntapamuutos'], icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>` },
  { href: '/palvelut/pienryhmavalennus', title: 'Pienryhmävalmennus', description: 'Energistä ryhmätreeniä enintään 10 hengen porukassa. Ihanteellinen, jos haluat treenata kaverin kanssa.', keywords: ['Ryhmäliikunta', 'Kaveriryhmät', 'Äidit'], icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>` },
  { href: '/palvelut/ulkotreenit', title: 'Ulkotreenit', description: 'Toiminnallinen treeni raittiissa ulkoilmassa. Sijainnit: Urheilupuisto ja Hirvensalo.', keywords: ['Ulkoliikunta', 'Kehonpainoharjoittelu', 'Toiminnallinen treeni'], icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>` },
  { href: '/palvelut/yrityspalvelut', title: 'Yrityspalvelut', description: 'Tyky-päivät, taukojumpat, aamujooga ja yritystreenit. Investoi henkilöstösi hyvinvointiin.', keywords: ['Tyky-päivä', 'Taukojumppa', 'Henkilöstöliikunta'], icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>` },
];
---

<PageLayout title="Palvelut | IloFit — Personal Trainer Turku" description="Tutustu IloFitin personal trainer -palveluihin Turussa. Yksilövalmennus, pienryhmävalmennus, ulkotreenit ja yrityspalvelut.">

  <!-- Hero -->
  <section class="bg-off-white pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">IloFit</p>
      <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">Palvelut</h1>
      <p class="text-lg text-charcoal-mid max-w-xl">Kaikki palvelut on suunniteltu auttamaan sinua saavuttamaan tavoitteesi — oli kyse sitten painonpudotuksesta, kiinteytymisestä tai yrityksen hyvinvoinnista.</p>
    </div>
  </section>

  <!-- Services grid -->
  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-8 md:grid-cols-2">
        {services.map((service) => (
          <a href={service.href} class="card-accent group rounded-xl border border-soft-border bg-white p-8 shadow-warm transition-all duration-300 hover:shadow-warm-md hover:-translate-y-1">
            <div class="mb-5 w-12 h-12 rounded-xl bg-pink-light flex items-center justify-center transition-colors group-hover:bg-pink text-pink-dark group-hover:text-white">
              <Fragment set:html={service.icon} />
            </div>
            <h2 class="font-display text-2xl font-semibold text-charcoal mb-3">{service.title}</h2>
            <p class="text-charcoal-mid leading-relaxed mb-5">{service.description}</p>
            <div class="flex flex-wrap gap-2 mb-5">
              {service.keywords.map((kw) => (
                <span class="rounded-full bg-off-white border border-soft-border px-3 py-1 text-xs text-charcoal-mid">{kw}</span>
              ))}
            </div>
            <span class="text-sm font-medium text-pink group-hover:text-pink-dark transition-colors">Lue lisää →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaBanner />

</PageLayout>
