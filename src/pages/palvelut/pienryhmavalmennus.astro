---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('palvelut', 'pienryhmavalmennus');
const c = entry.data;

const checkSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
---

<PageLayout title="Pienryhmävalmennus Turku | IloFit — Personal Trainer" description="Pienryhmäliikuntaa Turussa enintään 10 henkilölle. Energinen ryhmätreeni ammattivalmentajan ohjauksessa.">

  <section class="bg-off-white pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">{c.hero_eyebrow}</p>
          <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">{c.hero_heading}</h1>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">{c.hero_text}</p>
          <Button href="/yhteystiedot?palvelu=pienryhmavalmennus" size="lg">{c.hero_cta}</Button>
        </div>
        <div class="relative">
          <div class="w-full h-[420px] rounded-3xl overflow-hidden shadow-warm">
            <img src={c.hero_image} alt="Pienryhmävalmennus Turussa – IloFit" class="w-full h-full object-cover object-center grayscale" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
        <div class="rounded-2xl border border-soft-border bg-off-white p-8">
          <SectionHeader heading="Ryhmät ja hinnat" class="mb-8" />

          <p class="text-charcoal-mid text-lg font-semibold mb-3">{c.kettlebell_heading}</p>
          <p class="text-charcoal-mid text-sm mb-6">{c.kettlebell_time}</p>
          <div class="space-y-4">
            {c.kettlebell_prices.map((pkg) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{pkg.label}</span>
                <span class="text-pink font-semibold">{pkg.price}</span>
              </div>
            ))}
          </div>

          <p class="mb-6"></p>
          <p class="text-charcoal-mid text-lg font-semibold mb-3">{c.bootcamp_heading}</p>
          <p class="text-charcoal-mid text-sm mb-3">{c.bootcamp_desc}</p>
          <p class="text-charcoal-mid text-sm mb-1">{c.bootcamp_time1}</p>
          <p class="text-charcoal-mid text-sm mb-1">{c.bootcamp_time2}</p>
          <p class="text-charcoal-mid text-sm mb-6">{c.bootcamp_time3}</p>
          <div class="space-y-4">
            {c.bootcamp_prices.map((pkg) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{pkg.label}</span>
                <span class="text-pink font-semibold">{pkg.price}</span>
              </div>
            ))}
          </div>

          <p class="mb-6"></p>
          <div class="rounded-xl border border-pink/30 p-4">
            <p class="text-charcoal-mid text-sm mb-2">Huom: myös liikuntaedut käyvät!</p>
            <div class="mt-2 flex flex-wrap gap-2">
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Smartum</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">E-passi</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Edenred</span>
            </div>
          </div>
        </div>

        <div class="rounded-2xl border border-soft-border bg-white p-8">
          <SectionHeader heading={c.benefits_heading} class="mb-8" />
          <ul class="space-y-4">
            {c.benefits.map((b) => (
              <li class="flex items-start gap-3">
                <Fragment set:html={checkSvg} />
                <span class="text-charcoal-mid">{b}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-off-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <SectionHeader eyebrow={c.suitable_eyebrow} heading={c.suitable_heading} centered />
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {c.suitable_for.map((item) => (
          <div class="card-accent rounded-xl border border-soft-border bg-white p-6 shadow-warm">
            <h3 class="font-display text-xl font-semibold text-charcoal mb-2">{item.title}</h3>
            <p class="text-sm text-charcoal-mid leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-off-white py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader eyebrow={c.cta_eyebrow} heading={c.cta_heading} centered class="mb-6" />
      <Button href="/yhteystiedot?palvelu=pienryhmavalmennus" size="lg">{c.cta_button}</Button>
    </div>
  </section>

</PageLayout>
