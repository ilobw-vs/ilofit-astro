---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('palvelut', 'treeniohjelma');
const c = entry.data;

const checkSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
---

<PageLayout title="Treeniohjelma | IloFit — Personal Trainer" description="Yksilöllisesti räätälöity treeniohjelma kattavan taustatietolomakkeen ja haastattelun pohjalta.">

  <section class="bg-off-white pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">{c.hero_eyebrow}</p>
          <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">{c.hero_heading}</h1>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-4">{c.hero_text1}</p>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">{c.hero_text2}</p>
          <Button href="/taustatietolomake?palvelu=treeniohjelma" size="lg">{c.hero_cta}</Button>
        </div>
        <div class="relative">
          <div class="w-full h-[420px] rounded-3xl overflow-hidden shadow-warm">
            <img src={c.hero_image} alt="Treeniohjelma – IloFit" class="w-full h-full object-cover object-bottom grayscale" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <div class="rounded-2xl border border-soft-border bg-off-white p-8">
          <SectionHeader heading="Hinnat" class="mb-8" />
          <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4 mb-4">
            <span class="font-medium text-charcoal">{c.base_price_label}</span>
            <span class="text-pink font-semibold">{c.base_price}</span>
          </div>

          <p class="mb-6"></p>
          <p class="text-charcoal-mid text-lg font-semibold mb-6">{c.addons_heading}</p>
          <div class="space-y-4">
            {c.addons.map((addon) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{addon.label}</span>
                <span class="text-pink font-semibold">{addon.price}</span>
              </div>
            ))}
          </div>

          <p class="mb-6"></p>

          <div class="rounded-xl border border-pink/30 p-4 mb-8">
            <p class="text-charcoal-mid text-sm mb-2">Huom: myös liikuntaedut käyvät!</p>
            <div class="flex flex-wrap gap-2 mt-2">
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Smartum</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">E-passi</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Edenred</span>
            </div>
          </div>
          <Button href="/taustatietolomake?palvelu=treeniohjelma" class="w-full justify-center">Tilaa treeniohjelma</Button>
        </div>

        <div class="rounded-2xl border border-soft-border bg-white p-8">
          <SectionHeader heading={c.included_heading} class="mb-8" />
          <ul class="space-y-4">
            {c.included.map((item) => (
              <li class="flex items-start gap-3">
                <Fragment set:html={checkSvg} />
                <span class="text-charcoal-mid">{item}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>



</PageLayout>
