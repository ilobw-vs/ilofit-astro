---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('palvelut', 'treeniohjelma');
const c = entry.data;

const checkSvg = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-1"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
---

<PageLayout title="Treeniohjelma | IloFit — Personal Trainer" description="Yksilöllisesti räätälöity treeniohjelma kattavan taustatietolomakkeen ja haastattelun pohjalta.">

  <section class="bg-off-white pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">{c.hero_eyebrow}</p>
          <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">{c.hero_heading}</h1>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-4">{c.hero_text1}</p>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">{c.hero_text2}</p>
          <Button href="/taustatietolomake?palvelu=treeniohjelma" size="lg">{c.hero_cta}</Button>
        </div>
        <div class="relative">
          <div class="w-full h-[420px] rounded-3xl overflow-hidden shadow-warm">
            <img src={c.hero_image} alt="Treeniohjelma – IloFit" class="w-full h-full object-cover object-bottom grayscale" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <div class="rounded-2xl border border-soft-border bg-off-white p-8">
          <SectionHeader heading="Hinnat" class="mb-8" />
          <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4 mb-4">
            <span class="font-medium text-charcoal">{c.base_price_label}</span>
            <span class="text-pink font-semibold">{c.base_price}</span>
          </div>

          <p class="mb-6"></p>
          <p class="text-charcoal-mid text-lg font-semibold mb-6">{c.addons_heading}</p>
          <div class="space-y-4">
            {c.addons.map((addon) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{addon.label}</span>
                <span class="text-pink font-semibold">{addon.price}</span>
              </div>
            ))}
          </div>

          <p class="mb-6"></p>
          <p class="text-charcoal-mid text-lg font-semibold mb-3">{c.plus_heading}</p>
          <p class="text-charcoal-mid text-sm mb-6">{c.plus_desc}</p>
          <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4 mb-6">
            <span class="font-medium text-charcoal">{c.plus_price_label}</span>
            <span class="text-pink font-semibold">{c.plus_price}</span>
          </div>

          <div class="rounded-xl border border-pink/30 p-4 mb-8">
            <p class="text-charcoal-mid text-sm mb-2">Huom: myös liikuntaedut käyvät!</p>
            <div class="flex flex-wrap gap-2 mt-2">
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Smartum</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">E-passi</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Edenred</span>
            </div>
          </div>
          <Button href="/taustatietolomake?palvelu=treeniohjelma" class="w-full justify-center">Tilaa treeniohjelma</Button>
        </div>

        <div class="rounded-2xl border border-soft-border bg-white p-8">
          <SectionHeader heading={c.included_heading} class="mb-8" />
          <ul class="space-y-4">
            {c.included.map((item) => (
              <li class="flex items-start gap-3">
                <Fragment set:html={checkSvg} />
                <span class="text-charcoal-mid">{item}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 rounded-xl bg-pink-light border border-pink/20 px-4 py-3">
            <p class="text-xs text-pink-dark font-medium">{c.included_highlight}</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="bg-off-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <SectionHeader eyebrow={c.addon_cards_eyebrow} heading={c.addon_cards_heading} centered />
        <p class="text-charcoal-mid mt-4 max-w-xl mx-auto">{c.addon_cards_desc}</p>
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {c.addon_cards.map((addon) => (
          <div class="card-accent rounded-xl border border-soft-border bg-white p-6 shadow-warm flex flex-col">
            <div class="flex-1">
              <h3 class="font-display text-xl font-semibold text-charcoal mb-2">{addon.title}</h3>
              <p class="text-sm text-charcoal-mid leading-relaxed mb-4">{addon.desc}</p>
            </div>
            <div class="mt-auto pt-4 border-t border-soft-border">
              <span class="text-pink font-semibold">{addon.price}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <SectionHeader eyebrow={c.monthly_eyebrow} heading={c.monthly_heading} class="mb-6" />
          <p class="text-charcoal-mid leading-relaxed mb-6">{c.monthly_text}</p>
          <ul class="space-y-3 mb-8">
            {c.monthly_items.map((item) => (
              <li class="flex items-start gap-3">
                <Fragment set:html={checkSvg} />
                <span class="text-sm text-charcoal-mid">{item}</span>
              </li>
            ))}
          </ul>
          <div class="flex items-center gap-4">
            <div>
              <span class="font-display text-4xl font-semibold text-charcoal">{c.monthly_price}</span>
              <span class="text-charcoal-mid text-sm"> / kk</span>
            </div>
            <Button href="/taustatietolomake?palvelu=treeniohjelma+kuukausituki">{c.monthly_cta}</Button>
          </div>
        </div>
        <div class="rounded-2xl bg-charcoal p-8 text-white">
          <p class="text-xs font-medium uppercase tracking-widest text-pink mb-6">Esimerkki 3 kk jaksosta</p>
          <div class="space-y-6">
            {[
              { kk: 'Kk 1', title: 'Aloitus', desc: 'Treeniohjelma laaditaan, tavoitteet asetetaan.' },
              { kk: 'Kk 2', title: 'Tarkistus', desc: 'Käydään läpi kehitys, päivitetään ohjelma tarvittaessa.' },
              { kk: 'Kk 3', title: 'Tulosten arviointi', desc: 'Mitataan edistyminen ja suunnitellaan seuraava vaihe.' },
            ].map((step) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-pink/20 flex items-center justify-center">
                  <span class="text-xs font-semibold text-pink">{step.kk}</span>
                </div>
                <div>
                  <p class="font-semibold text-white text-sm mb-0.5">{step.title}</p>
                  <p class="text-xs text-white/60 leading-relaxed">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-off-white py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-2xl border border-soft-border bg-white p-8 flex flex-col sm:flex-row items-start sm:items-center gap-6">
        <div class="flex-1">
          <p class="text-xs font-medium uppercase tracking-widest text-pink mb-2">{c.update_eyebrow}</p>
          <h3 class="font-display text-2xl font-semibold text-charcoal mb-2">{c.update_heading}</h3>
          <p class="text-charcoal-mid text-sm leading-relaxed">{c.update_desc}</p>
        </div>
        <div class="flex-shrink-0 text-right">
          <p class="font-display text-3xl font-semibold text-charcoal mb-1">{c.update_price}</p>
          <a href="/taustatietolomake?palvelu=ohjelmapäivitys" class="inline-block mt-3 rounded-lg border border-soft-border px-5 py-2.5 text-sm font-medium text-charcoal hover:border-pink hover:text-pink transition-colors">
            {c.update_cta}
          </a>
        </div>
      </div>
    </div>
  </section>

</PageLayout>
