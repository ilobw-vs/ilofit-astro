---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';

const serviceOptions = [{title:'Aamujooga',desc:'Rauhallinen joogasessio aamun aloitukseksi. Venyttää, rentouttaa ja virittää mielen päivään.'},{title:'HIIT-treeni',desc:'Tehokasta intervallitreeniä, joka sopii kaikille kuntotasoille. Energinen ja motivoiva kokemus.'},{title:'Taukojumppa',desc:'15–20 minuutin liikkuvuus- ja venyttelyhetki kesken työpäivän. Virkistää ja ehkäisee jännitystiloja.'},{title:'Ulkocircuit',desc:'Toiminnallinen kiertotreeni ulkona. Ryhmähenki paranee, keho liikkuu ja mieli virkistyy.'},{title:'Räätälöity paketti',desc:'Suunnitellaan yrityksellesi täysin yksilöllinen liikuntaohjelma — tarpeidesi mukaan.'}];
const benefits = ['Parantaa henkilöstön työssä jaksamista','Vähentää sairauspoissaoloja','Lisää tiimien yhteisöllisyyttä','Parantaa työmotivaatiota ja -iloa','Positiivinen työnantajamielikuva','Kevytrakenteeinen ja helppo järjestää'];
const steps = [{n:'01',title:'Ota yhteyttä',desc:'Kerro tarpeistasi ja toiveistasi. Sovitaan tapaaminen tai puhelinkeskustelu.'},{n:'02',title:'Räätälöity tarjous',desc:'Suunnittelen yrityksellenne sopivan paketin — aikatauluun, budjettiin ja toiveisiin perustuen.'},{n:'03',title:'Treeni toteutuu',desc:'Tulen teille tai sovitulle paikalle. Kaikki tarvikkeet mukana — teidän ei tarvitse järjestää mitään.'}];
const checkSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
---

<PageLayout title="Yrityspalvelut Turku | IloFit — Tyky-päivät & Yritystreeni" description="Tyky-päivät, yritystreenit ja taukojumpat Turussa. Henkilöstöliikuntaa ammattivalmentajan ohjauksessa.">

  <section class="bg-charcoal pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <nav class="flex items-center gap-2 text-xs text-white/50 mb-6">
        <a href="/palvelut" class="hover:text-white transition-colors">Palvelut</a>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="text-white/80">Yrityspalvelut</span>
      </nav>
      <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">Palvelut</p>
      <h1 class="font-display text-5xl font-semibold text-white sm:text-6xl mb-6">Yrityspalvelut</h1>
      <p class="text-xl text-white/70 max-w-xl leading-relaxed mb-10">Investoi henkilöstösi hyvinvointiin. Ammattitaitoisesti toteutetut tyky-päivät ja yritystreenit, jotka jäävät mieleen.</p>
      <div class="flex flex-wrap gap-4">
        <Button href="/yhteystiedot" size="lg">Pyydä tarjous</Button>
        <a href="mailto:ilona@ilofit.com" class="inline-flex items-center gap-2 rounded-lg border border-[1.5px] border-white/40 px-8 py-4 text-base font-medium text-white hover:bg-white/10 transition-colors">ilona@ilofit.com</a>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16"><SectionHeader eyebrow="Palvelut" heading="Mitä tarjoamme?" centered /></div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {serviceOptions.map((opt) => (
          <div class="card-accent rounded-xl border border-soft-border bg-off-white p-6 shadow-warm">
            <div class="mb-4 w-10 h-10 rounded-lg bg-pink-light flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C97A8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            </div>
            <h3 class="font-display text-xl font-semibold text-charcoal mb-2">{opt.title}</h3>
            <p class="text-sm text-charcoal-mid leading-relaxed">{opt.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-off-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <SectionHeader eyebrow="Hyödyt" heading="Miksi panostaa henkilöstöliikuntaan?" class="mb-8" />
          <ul class="space-y-4">
            {benefits.map((b) => (<li class="flex items-start gap-3"><Fragment set:html={checkSvg} /><span class="text-charcoal-mid">{b}</span></li>))}
          </ul>
        </div>
        <div class="rounded-2xl bg-pink-light p-8">
          <h3 class="font-display text-2xl font-semibold text-charcoal mb-4">Näin tilaat</h3>
          <div class="space-y-6">
            {steps.map((step) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-pink flex items-center justify-center">
                  <span class="font-display text-sm font-semibold text-white">{step.n}</span>
                </div>
                <div>
                  <p class="font-semibold text-charcoal text-sm mb-1">{step.title}</p>
                  <p class="text-xs text-charcoal-mid leading-relaxed">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader eyebrow="Tarjous" heading="Pyydä tarjous yrityksellesi" centered class="mb-6" />
      <p class="text-charcoal-mid mb-8">Kerro lyhyesti yrityksestäsi ja toiveistasi — palaan sinulle tarjouksen kanssa.</p>
      <Button href="/yhteystiedot" size="lg">Lähetä tarjouspyyntö</Button>
    </div>
  </section>

</PageLayout>
