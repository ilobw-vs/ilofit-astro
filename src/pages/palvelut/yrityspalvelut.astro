---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('palvelut', 'yrityspalvelut');
const c = entry.data;

const checkSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
---

<PageLayout title="Yrityspalvelut Turku | IloFit — Tyky-päivät & Yritystreeni" description="Tyky-päivät, yritystreenit ja taukojumpat Turussa. Henkilöstöliikuntaa ammattivalmentajan ohjauksessa.">

  <section class="bg-off-white pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">{c.hero_eyebrow}</p>
          <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">{c.hero_heading}</h1>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">{c.hero_text}</p>
          <Button href="/yhteystiedot" size="lg">{c.hero_cta}</Button>
        </div>
        <div class="relative">
          <div class="w-full h-[420px] rounded-3xl overflow-hidden shadow-warm">
            <img src={c.hero_image} alt="Yrityspalvelut – IloFit" class="w-full h-full object-cover object-bottom grayscale" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <SectionHeader heading={c.services_heading} centered />
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {c.services.map((opt) => (
          <div class="card-accent rounded-xl border border-soft-border bg-off-white p-6 shadow-warm">
            <div class="mb-4 w-10 h-10 rounded-lg bg-pink-light flex items-center justify-center">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C97A8E" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            </div>
            <h3 class="font-display text-xl font-semibold text-charcoal mb-2">{opt.title}</h3>
            <p class="text-sm text-charcoal-mid leading-relaxed">{opt.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-off-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <SectionHeader eyebrow={c.benefits_eyebrow} heading={c.benefits_heading} class="mb-8" />
          <ul class="space-y-4">
            {c.benefits.map((b) => (
              <li class="flex items-start gap-3">
                <Fragment set:html={checkSvg} />
                <span class="text-charcoal-mid">{b}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl bg-pink-light p-8">
          <h3 class="font-display text-2xl font-semibold text-charcoal mb-4">{c.steps_heading}</h3>
          <div class="space-y-6">
            {c.steps.map((step) => (
              <div class="flex gap-4">
                <div class="flex-shrink-0 w-10 h-10 rounded-full bg-pink flex items-center justify-center">
                  <span class="font-display text-sm font-semibold text-white">{step.n}</span>
                </div>
                <div>
                  <p class="font-semibold text-charcoal text-sm mb-1">{step.title}</p>
                  <p class="text-xs text-charcoal-mid leading-relaxed">{step.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader eyebrow={c.cta_eyebrow} heading={c.cta_heading} centered class="mb-6" />
      <p class="text-charcoal-mid mb-8">{c.cta_text}</p>
      <Button href="/yhteystiedot" size="lg">{c.cta_button}</Button>
    </div>
  </section>

</PageLayout>
