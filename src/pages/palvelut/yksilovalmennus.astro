---
import PageLayout from '../../layouts/PageLayout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import Button from '../../components/ui/Button.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('palvelut', 'yksilovalmennus');
const c = entry.data;

const checkSvg = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0 mt-0.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`;
---

<PageLayout title="Yksilövalmennus Turku | IloFit — Personal Trainer" description="Henkilökohtainen yksilövalmennus Turussa. Räätälöity treeniohjelma ja jatkuva tuki. Varaa ilmainen alkukartoitus.">

  <section class="bg-off-white pt-36 pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-xs font-medium uppercase tracking-widest text-pink mb-3">{c.hero_eyebrow}</p>
          <h1 class="font-display text-5xl font-semibold text-charcoal sm:text-6xl mb-6">{c.hero_heading}</h1>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">{c.hero_text1}</p>
          <p class="text-xl text-charcoal-mid max-w-xl leading-relaxed mb-8">{c.hero_text2}</p>
          <div class="flex flex-col items-start gap-3">
            <Button href="/yhteystiedot" size="lg">{c.hero_cta_primary}</Button>
          </div>
        </div>
        <div class="relative">
          <div class="w-full h-[420px] rounded-3xl overflow-hidden shadow-warm">
            <img src={c.hero_image} alt="Yksilövalmennus Turussa – IloFit" class="w-full h-full object-cover object-top grayscale" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <div class="rounded-2xl border border-soft-border bg-off-white p-8">
          <SectionHeader heading="Hinnat" class="mb-8" />
          <div class="mb-6 rounded-xl border border-pink/30 p-4">
            <p class="text-charcoal-mid text-sm mb-2">Huom: myös liikuntaedut käyvät!</p>
            <div class="mt-2 flex flex-wrap gap-2">
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Smartum</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">E-passi</span>
              <span class="rounded-full bg-pink-light px-3 py-1 text-xs font-medium text-charcoal">Edenred</span>
            </div>
          </div>

          <p class="text-charcoal-mid text-lg font-semibold mb-3">{c.monthly_prices_heading}</p>
          <p class="text-charcoal-mid text-sm mb-6">{c.monthly_prices_note}</p>
          <div class="space-y-4">
            {c.monthly_prices.map((pkg) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{pkg.label}</span>
                <span class="text-pink font-semibold">{pkg.price}</span>
              </div>
            ))}
          </div>

          <p class="mb-6"></p>
          <p class="text-charcoal-mid text-lg font-semibold mb-3">{c.package_prices_heading}</p>
          <p class="text-charcoal-mid text-sm mb-6">{c.package_prices_note}</p>
          <div class="space-y-4">
            {c.package_prices.map((pkg) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{pkg.label}</span>
                <span class="text-pink font-semibold">{pkg.price}</span>
              </div>
            ))}
          </div>

          <p class="mb-6"></p>
          <p class="text-charcoal-mid text-lg font-semibold mb-6">{c.other_prices_heading}</p>
          <div class="space-y-4">
            {c.other_prices.map((pkg) => (
              <div class="flex items-center justify-between rounded-xl border border-soft-border bg-white p-4">
                <span class="font-medium text-charcoal">{pkg.label}</span>
                <span class="text-pink font-semibold">{pkg.price}</span>
              </div>
            ))}
          </div>
          <div class="mt-8">
            <Button href="/yhteystiedot" class="w-full justify-center">Kysy lisää tai varaa aika</Button>
          </div>
        </div>

        <div class="rounded-2xl border border-soft-border bg-white p-8">
          <SectionHeader heading={c.included_heading} class="mb-8" />
          <ul class="space-y-4">
            {c.included.map((item) => (
              <li class="flex items-start gap-3">
                <Fragment set:html={checkSvg} />
                <span class="text-charcoal-mid">{item}</span>
              </li>
            ))}
          </ul>
        </div>

      </div>
    </div>
  </section>

  <section class="bg-off-white py-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <SectionHeader eyebrow={c.goals_eyebrow} heading={c.goals_heading} centered />
      </div>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {c.goals.map((goal) => (
          <div class="card-accent rounded-xl border border-soft-border bg-white p-6 shadow-warm">
            <h3 class="font-display text-xl font-semibold text-charcoal mb-3">{goal.title}</h3>
            <p class="text-sm text-charcoal-mid leading-relaxed">{goal.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <section class="bg-white py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <SectionHeader eyebrow={c.cta_eyebrow} heading={c.cta_heading} centered class="mb-6" />
      <p class="text-charcoal-mid mb-8">{c.cta_text}</p>
      <Button href="/yhteystiedot" size="lg">{c.cta_button}</Button>
    </div>
  </section>

</PageLayout>
