---
import SectionHeader from '../ui/SectionHeader.astro';

const services = [
  {
    href: '/palvelut/yksilovalmennus',
    label: 'Yksilövalmennus',
    description: 'Henkilökohtainen valmennus räätälöidyllä ohjelmalla ja jatkuvalla tuella. Täydellinen juuri sinun tavoitteillesi.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  },
  {
    href: '/palvelut/pienryhmavalmennus',
    label: 'Pienryhmävalmennus',
    description: 'Energistä ryhmätreeniä enintään 10 hengen porukassa. Ryhmän motivaatio, yksilöllinen huomio.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
  {
    href: '/palvelut/ulkotreenit',
    label: 'Ulkotreenit',
    description: 'Toiminnallinen treeni raittiissa ilmassa.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>`,
  },
  {
    href: '/palvelut/yrityspalvelut',
    label: 'Yrityspalvelut',
    description: 'Tyky-päivät, taukojumpat ja yritystreenit. Hyvinvoiva henkilöstö on yrityksen voimavara.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
  },
  {
    href: '/palvelut/verkkovalmennus',
    label: 'Verkkovalmennus',
    description: 'Henkilökohtainen etävalmennus räätälöidyllä ohjelmalla.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
  },
  {
    href: '/palvelut/treeniohjelma',
    label: 'Treeniohjelma',
    description: 'Yksilöllisesti räätälöity treeniohjelma kattavan taustatietolomakkeen ja haastattelun pohjalta.',
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
  },
];
---

<section class="bg-off-white py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <SectionHeader
        eyebrow="Palvelut"
        heading="Miten voin auttaa sinua?"
        centered
      />
    </div>

    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {services.map((service) => (
        <a
          href={service.href}
          class="card-accent group relative rounded-xl border border-soft-border bg-white p-6 shadow-warm transition-all duration-300 hover:shadow-warm-md hover:-translate-y-1"
        >
          <div class="mb-4 w-11 h-11 rounded-lg bg-pink-light flex items-center justify-center transition-colors group-hover:bg-pink text-pink-dark group-hover:text-white">
            <Fragment set:html={service.icon} />
          </div>
          <h3 class="font-display text-xl font-semibold text-charcoal mb-2">
            {service.label}
          </h3>
          <p class="text-sm text-charcoal-mid leading-relaxed mb-4">
            {service.description}
          </p>
          <span class="text-xs font-medium text-pink transition-colors group-hover:text-pink-dark">
            Lue lisää →
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
