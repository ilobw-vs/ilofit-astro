---
import { getEntry } from 'astro:content';
const { data: c } = await getEntry('etusivu', 'hero');
---

<section class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Dark background -->
  <div class="absolute inset-0 z-0 bg-charcoal"></div>

  <!-- Person image — right half, zoomed to face+upper body on desktop -->
  <img
    src={c.image}
    srcset="/images/ilona-800.webp 800w, /images/ilona.webp 1400w"
    sizes="(max-width: 1024px) 100vw, 50vw"
    alt=""
    width="1400"
    height="2100"
    fetchpriority="high"
    decoding="async"
    class="absolute right-0 top-0 h-full w-full lg:w-1/2 object-cover object-top z-0 scale-[1.5] origin-top-left"
  />
  <!-- Mobile overlay for text readability -->
  <div class="absolute inset-0 z-[1] bg-charcoal/65 lg:hidden"></div>
  <!-- Mobile bottom fade — hides lower body below buttons -->
  <div class="absolute bottom-0 inset-x-0 h-[50vh] z-[2] bg-gradient-to-t from-charcoal via-charcoal/80 to-transparent lg:hidden"></div>
  <!-- Desktop: smooth gradient — solid charcoal left, fades to semi-transparent over image -->
  <div
    class="absolute inset-0 z-[1] hidden lg:block"
    style="background: linear-gradient(to right, #2D2D2D 48%, rgba(45,45,45,0.80) 62%, rgba(45,45,45,0.60) 100%)"
  ></div>

  <!-- Pink wash accent -->
  <div class="absolute inset-0 z-[1] opacity-10 bg-gradient-to-br from-pink via-transparent to-transparent"></div>

  <!-- Content -->
  <div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 w-full py-32 pt-40">
    <div class="max-w-2xl hero-content">
      <h1 class="hero-eyebrow mb-4 text-xs font-medium font-sans uppercase tracking-widest text-pink opacity-0 translate-y-5">
        {c.eyebrow}
      </h1>

      <p class="hero-heading font-display text-6xl font-semibold text-white sm:text-7xl lg:text-8xl leading-[1.05] mb-6 opacity-0 translate-y-8">
        {c.heading}
      </p>

      <p class="hero-sub text-lg text-white/80 leading-relaxed mb-10 max-w-lg opacity-0 translate-y-5">
        {c.subheading}
      </p>

      <div class="hero-cta flex flex-wrap gap-4 opacity-0 translate-y-5">
        <a
          href={c.cta_primary_href}
          class="rounded-lg bg-pink px-8 py-4 text-base font-medium text-white transition-all duration-200 hover:bg-pink-dark hover:scale-[1.02] active:scale-100"
        >
          {c.cta_primary}
        </a>
        <a
          href={c.cta_secondary_href}
          class="rounded-lg border border-[1.5px] border-white/60 px-8 py-4 text-base font-medium text-white transition-all duration-200 hover:bg-white/10"
        >
          {c.cta_secondary}
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-indicator absolute bottom-8 left-1/2 -translate-x-1/2 z-10 opacity-0">
    <div class="h-10 w-px bg-white/30 animate-pulse"></div>
  </div>
</section>

<style>
  @keyframes fadeInUp {
    to { opacity: 1; transform: translateY(0); }
  }
  .hero-eyebrow { animation: fadeInUp 0.6s ease forwards 0.1s; }
  .hero-heading  { animation: fadeInUp 0.8s cubic-bezier(0.22, 1, 0.36, 1) forwards 0.2s; color: white}
  .hero-sub      { animation: fadeInUp 0.7s ease forwards 0.4s; }
  .hero-cta      { animation: fadeInUp 0.6s ease forwards 0.55s; }
  .scroll-indicator { animation: fadeInUp 0.8s ease forwards 1.2s; }
</style>
