---
import SectionHeader from '../ui/SectionHeader.astro';

const testimonials = [
  {
    name: 'Maria K.',
    quote: 'Ehdottomasti yks viikon kohokohdista! Vaihtuvat, tehokkaat liikkeet - Ilonan treenit on ihan parasta',
    service: 'Ulkotreenit',
  },
  {
    name: 'Sanna L.',
    quote: 'Saliharjoitteluni on Ilonan tekemillä ohjelmilla selvästi monipuolistunut. Aiemmin treenini on painottunut ylävartaloon, mutta nyt mukaan on tullut tehokkaita jalka- ja keskivartaloliikkeitä, jotka tukevat lajiharjoittelua.',
    service: 'Treeniohjelmat',
  },
  {
    name: 'Tiimi Yritys Oy',
    quote: 'Ilonan yksilövalmennus muutti suhtautumistani treeniin ja uskon että nämä oivallukset kantavat pitkälle tulevaisuuteen. Sain juuri minulle sopivan, monipuolisen treeniohjelman niin sisä-  kuin ulkotreeneihin sekä parannusvinkkejä ruokavalioon. Olen ihan yllättynyt miten uskalsin haastaa itseäni fiksusti, ja olenkin alkanut nähdä tuloksia jo muutamassa viikossa. Oli todella kivaa harjoitella Ilonan kanssa - suosittelen lämpimästi!',
    service: 'Yksilövalmennus',
  },
  {
    name: 'Tiimi Yritys Oy',
    quote: 'Oli niin tarpeellinen treeni viimeksi. Mulla tuntui vielä eilenkin pakaroissa ja rintalihaksissa.',
    service: 'Ulkotreenit',
  },
  {
    name: 'Tiimi Yritys Oy',
    quote: 'Ilonan tekemissä kuntosaliohjelmissa liikkeet ovat hauskoja ja tehokkaita. Niissä on paljon uutta kokeneemallekin kuntosaliharrastajalle. Ohjelmien räätälöiminen yhteistyössä omiin tarpeisiin sopivaksi oli Ilonan kanssa sujuvaa"',
    service: 'Treeniohjelmat',
  },
  {
    name: 'Tiimi Yritys Oy',
    quote: 'Kiitos kovasti taas eilisestä! Tuntuu kamalan hyvältä!:) Tämä lihaskipu on koukuttavaa.',
    service: 'Ulkotreenit',
  },
  {
    name: 'Tiimi Yritys Oy',
    quote: 'Ihana treenata ulkona porukalla! Monipuolista ja helppoa hikiliikuntaa',
    service: 'Ulkotreenit',
  },
  {
    name: 'Tiimi Yritys Oy',
    quote: 'Huh, mikä ohjelma! Ihan huippu ja nyt mentiin sitten ihan uudelle levelille, kiitos! Hiki pinnassa täällä ihan eri tavalla, oli mukavasti haastetta. Palaan asiaan, kun tarvitsen taas päivitystä muutaman kuukauden päästä!',
    service: 'Treeniohjelmat',
  },

];

const starSvg = `<svg width="14" height="14" viewBox="0 0 24 24" fill="#E8A0B0" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
---

<section class="bg-pink-light py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <SectionHeader
        eyebrow="Asiakaskokemuksia"
        heading="Mitä asiakkaat sanovat"
        centered
      />
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {testimonials.map((t) => (
        <div class="rounded-xl bg-white p-8 shadow-warm">
          <div class="flex gap-0.5 mb-4">
            {[...Array(5)].map(() => (
              <Fragment set:html={starSvg} />
            ))}
          </div>
          <blockquote class="text-charcoal-mid leading-relaxed text-sm mb-6 italic">
            &ldquo;{t.quote}&rdquo;
          </blockquote>
          <div>
            <p class="text-xs text-pink mt-0.5">{t.service}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
