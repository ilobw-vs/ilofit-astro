---
import { getEntry } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';

const { data: c } = await getEntry('etusivu', 'kokemuksia');

interface Review {
  author: string;
  service: string;
  text: string;
  rating: number;
}

const reviewSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "IloFit",
  "@id": "https://ilofit.com",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": (c.reviews.reduce((sum: number, r: Review) => sum + r.rating, 0) / c.reviews.length).toFixed(1),
    "reviewCount": c.reviews.length,
    "bestRating": 5,
    "worstRating": 1,
  },
  "review": c.reviews.map((r: Review) => ({
    "@type": "Review",
    "author": { "@type": "Person", "name": r.author },
    "reviewRating": { "@type": "Rating", "ratingValue": r.rating, "bestRating": 5 },
    "reviewBody": r.text,
    "name": r.service,
  })),
};

const starSvg = `<svg width="14" height="14" viewBox="0 0 24 24" fill="#E8A0B0" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`;
---

<script type="application/ld+json" set:html={JSON.stringify(reviewSchema)} />

<section class="bg-pink-light py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <SectionHeader
        eyebrow={c.eyebrow}
        heading={c.heading}
        centered
      />
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {c.reviews.map((r: Review) => (
        <div class="rounded-xl bg-white p-8 shadow-warm">
          <div class="flex gap-0.5 mb-4">
            {[...Array(r.rating)].map(() => (
              <Fragment set:html={starSvg} />
            ))}
          </div>
          <blockquote class="text-charcoal-mid leading-relaxed text-sm mb-6 italic">
            &ldquo;{r.text}&rdquo;
          </blockquote>
          <div>
            <p class="text-xs text-pink mt-0.5">{r.service}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
