---
import { getEntry } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';
const { data: c } = await getEntry('etusivu', 'intro');
---

<section id="ilona" class="bg-white py-24 lg:py-32">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-16 lg:grid-cols-2 lg:gap-24 items-center">

      <!-- Photo (hidden on mobile) -->
      <div class="relative hidden lg:block">
        <div class="relative aspect-[4/5] max-w-md mx-auto lg:mx-0 overflow-hidden rounded-2xl shadow-warm-md">
          <img
            src={c.image}
            alt="Ilona Salomäki — Personal Trainer Turku"
            class="w-full h-full object-cover"
          />
        </div>
        <!-- Decorative pink accents -->
        <div class="absolute -bottom-4 -right-4 w-32 h-32 rounded-full bg-pink-light opacity-60 -z-10"></div>
        <div class="absolute -top-4 -left-4 w-20 h-20 rounded-full bg-pink/20 -z-10"></div>
      </div>

      <!-- Text -->
      <div>
        <SectionHeader
          eyebrow={c.eyebrow}
          heading={c.heading}
          class="mb-6"
        />
        {c.paragraphs.map((p: string) => (
          <p class="text-charcoal-mid leading-relaxed text-md mb-6">{p}</p>
        ))}
      </div>
    </div>
  </div>
</section>
