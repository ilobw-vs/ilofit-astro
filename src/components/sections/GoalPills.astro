---
import { getEntry } from 'astro:content';
import SectionHeader from '../ui/SectionHeader.astro';

const { data: c } = await getEntry('etusivu', 'tavoitteet');
---

<section class="bg-white py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
    <SectionHeader
      eyebrow={c.eyebrow}
      heading={c.heading}
      centered
      class="mb-12"
    />
    <div class="flex flex-wrap justify-center gap-3">
      {c.goals.map((goal: { label: string; href: string }) => (
        <a
          href={goal.href}
          class="rounded-full border border-soft-border bg-off-white px-5 py-2.5 text-sm font-medium text-charcoal-mid transition-all duration-200 hover:border-pink hover:bg-pink-light hover:text-charcoal"
        >
          {goal.label}
        </a>
      ))}
    </div>
  </div>
</section>
