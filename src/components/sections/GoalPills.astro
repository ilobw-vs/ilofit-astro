---
import SectionHeader from '../ui/SectionHeader.astro';

const goals = [
  { label: 'Painonpudotus', href: '/palvelut/yksilovalmennus' },
  { label: 'Kiinteytyminen', href: '/palvelut/yksilovalmennus' },
  { label: 'Lihasmassan kasvatus', href: '/palvelut/yksilovalmennus' },
  { label: 'Elämäntapamuutos', href: '/palvelut/yksilovalmennus' },
  { label: 'Arjen energisyys', href: '/palvelut/yksilovalmennus' },
  { label: 'Kehonhuolto', href: '/palvelut/yksilovalmennus' },
  { label: 'Yritystreeni', href: '/palvelut/yrityspalvelut' },
  { label: 'Ryhmäliikunta', href: '/palvelut/pienryhmavalmennus' },
  { label: 'Ulkoilma-aktiviteetti', href: '/palvelut/ulkotreenit' },
];
---

<section class="bg-white py-24">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
    <SectionHeader
      eyebrow="Tavoitteet"
      heading="Mitkä ovat sinun tavoitteesi?"
      centered
      class="mb-12"
    />
    <div class="flex flex-wrap justify-center gap-3">
      {goals.map((goal) => (
        <a
          href={goal.href}
          class="rounded-full border border-soft-border bg-off-white px-5 py-2.5 text-sm font-medium text-charcoal-mid transition-all duration-200 hover:border-pink hover:bg-pink-light hover:text-charcoal"
        >
          {goal.label}
        </a>
      ))}
    </div>
  </div>
</section>
