---
const navLinks = [
  { label: 'Treeniohjelma', href: '/palvelut/treeniohjelma' },
];

const personal_services = [
  { label: 'Henkilökohtainen valmennus', href: '/palvelut/yksilovalmennus' },
];

const group_services = [
  { label: 'Pienryhmävalmennus', href: '/palvelut/pienryhmavalmennus' },
  { label: 'Ulkotreenit', href: '/palvelut/ulkotreenit' },
  { label: 'Yrityspalvelut', href: '/palvelut/yrityspalvelut' },
];

const training_programs = [
  { label: 'Treeniohjelma', href: '/palvelut/treeniohjelma' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => pathname.includes(href);
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 bg-white">
  <nav class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-20 items-center justify-between">

      <!-- Logo -->
      <a href="/" class="flex-shrink-0">
        <img
          src="/images/IloFit_logo_musta_edited (1).png"
          alt="IloFit"
          width="120"
          height="48"
          class="h-10 w-auto object-contain"
        />
      </a>

      <!-- Desktop nav -->
      <div class="hidden lg:flex lg:items-center lg:gap-8">

        <!-- Personal Services dropdown -->
        <div class="relative" id="personal-services-dropdown">
          <button
            id="personal-services-btn"
            class={`flex items-center gap-1 text-sm font-medium transition-colors hover:text-pink ${pathname.includes('/palvelut') ? 'text-pink' : 'text-charcoal'}`}
          >
            Yksilövalmennus
            <svg id="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>

          <div
            id="personal-services-menu"
            class="absolute top-full left-1/2 -translate-x-1/2 pt-2 hidden"
          >
            <div class="w-56 rounded-xl border border-soft-border bg-white p-2 shadow-warm-md">
              {personal_services.map((s) => (
                <a
                  href={s.href}
                  class={`block rounded-lg px-4 py-2.5 text-sm transition-colors hover:bg-pink-light hover:text-charcoal ${isActive(s.href) ? 'bg-pink-light text-charcoal font-medium' : 'text-charcoal-mid'}`}
                >
                  {s.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        <!-- Group Services dropdown -->
        <div class="relative" id="group-services-dropdown">
          <button
            id="group-services-btn"
            class={`flex items-center gap-1 text-sm font-medium transition-colors hover:text-pink ${pathname.includes('/palvelut') ? 'text-pink' : 'text-charcoal'}`}
          >
            Ryhmät ja Yritykset
            <svg id="chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>

          <div
            id="group-services-menu"
            class="absolute top-full left-1/2 -translate-x-1/2 pt-2 hidden"
          >
            <div class="w-56 rounded-xl border border-soft-border bg-white p-2 shadow-warm-md">
              {group_services.map((s) => (
                <a
                  href={s.href}
                  class={`block rounded-lg px-4 py-2.5 text-sm transition-colors hover:bg-pink-light hover:text-charcoal ${isActive(s.href) ? 'bg-pink-light text-charcoal font-medium' : 'text-charcoal-mid'}`}
                >
                  {s.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        {navLinks.map((item) => (
          <a
            href={item.href}
            class={`text-sm font-medium transition-colors hover:text-pink ${isActive(item.href) ? 'text-pink' : 'text-charcoal'}`}
          >
            {item.label}
          </a>
        ))}

        <a
          href="/yhteystiedot"
          class="rounded-lg bg-pink px-5 py-2.5 text-sm font-medium text-white transition-all duration-200 hover:bg-pink-dark hover:scale-[1.02] active:scale-100"
        >
          Varaa aika →
        </a>
      </div>

      <!-- Mobile hamburger -->
      <button id="mobile-btn" class="lg:hidden p-2 text-charcoal" aria-label="Avaa valikko">
        <svg id="icon-menu" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg id="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>

    <!-- Mobile menu -->
    <div id="mobile-menu" class="lg:hidden border-t border-soft-border pb-6 pt-4 hidden">

      <!-- Personal Services accordion -->
      <div class="mb-2">
        <button
          id="mobile-services-btn"
          class="flex w-full items-center justify-between px-2 py-3 text-sm font-medium text-charcoal"
        >
          Palvelut
          <svg id="mobile-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div id="mobile-services-menu" class="hidden ml-4 border-l-2 border-pink-light pl-4">
          {personal_services.map((s) => (
            <a
              href={s.href}
              class={`block py-2.5 text-sm transition-colors ${isActive(s.href) ? 'text-pink font-medium' : 'text-charcoal-mid'}`}
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>

     <!-- Group Services accordion -->
      <div class="mb-2">
        <button
          id="mobile-services-btn"
          class="flex w-full items-center justify-between px-2 py-3 text-sm font-medium text-charcoal"
        >
          Palvelut
          <svg id="mobile-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div id="mobile-services-menu" class="hidden ml-4 border-l-2 border-pink-light pl-4">
          {group_services.map((s) => (
            <a
              href={s.href}
              class={`block py-2.5 text-sm transition-colors ${isActive(s.href) ? 'text-pink font-medium' : 'text-charcoal-mid'}`}
            >
              {s.label}
            </a>
          ))}
        </div>
      </div>

      {navLinks.map((item) => (
        <a
          href={item.href}
          class={`block px-2 py-3 text-sm font-medium transition-colors ${isActive(item.href) ? 'text-pink' : 'text-charcoal'}`}
        >
          {item.label}
        </a>
      ))}

      <div class="mt-4 px-2">
        <a
          href="/yhteystiedot"
          class="block w-full rounded-lg bg-pink px-5 py-3 text-center text-sm font-medium text-white transition-colors hover:bg-pink-dark"
        >
          Varaa aika →
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const navbar = document.getElementById('navbar')!;
  const mobileBtn = document.getElementById('mobile-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;
  const iconMenu = document.getElementById('icon-menu')!;
  const iconClose = document.getElementById('icon-close')!;
  const personal_servicesDropdown = document.getElementById('personal-services-dropdown')!;
  const personal_servicesMenu = document.getElementById('personal-services-menu')!;
  const group_servicesDropdown = document.getElementById('group-services-dropdown')!;
  const group_servicesMenu = document.getElementById('group-services-menu')!;
  const chevron = document.getElementById('chevron')!;
  const mobileServicesBtn = document.getElementById('mobile-services-btn')!;
  const mobileServicesMenu = document.getElementById('mobile-services-menu')!;
  const mobileChevron = document.getElementById('mobile-chevron')!;

  // Scroll: transparent → frosted glass
  const updateNavbar = () => {
    const scrolled = window.scrollY > 60;
    const mobileOpen = !mobileMenu.classList.contains('hidden');
    if (scrolled || mobileOpen) {
      navbar.classList.add('bg-white/95', 'backdrop-blur-md', 'shadow-warm');
    } else {
      navbar.classList.remove('bg-white/95', 'backdrop-blur-md', 'shadow-warm');
    }
  };
  window.addEventListener('scroll', updateNavbar, { passive: true });
  updateNavbar();

  // Mobile toggle
  mobileBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden');
    mobileMenu.classList.toggle('hidden');
    iconMenu.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    updateNavbar();
  });

  // Desktop services dropdown (hover)
  personal_servicesDropdown.addEventListener('mouseenter', () => {
    personal_servicesMenu.classList.remove('hidden');
    chevron.style.transform = 'rotate(180deg)';
  });
  personal_servicesDropdown.addEventListener('mouseleave', () => {
    personal_servicesMenu.classList.add('hidden');
    chevron.style.transform = 'rotate(0deg)';
  });

// Desktop services dropdown (hover)
  group_servicesDropdown.addEventListener('mouseenter', () => {
    group_servicesMenu.classList.remove('hidden');
    chevron.style.transform = 'rotate(180deg)';
  });
  group_servicesDropdown.addEventListener('mouseleave', () => {
    group_servicesMenu.classList.add('hidden');
    chevron.style.transform = 'rotate(0deg)';
  });

  // Mobile services accordion
  mobileServicesBtn.addEventListener('click', () => {
    const isOpen = !mobileServicesMenu.classList.contains('hidden');
    mobileServicesMenu.classList.toggle('hidden');
    mobileChevron.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
  });
</script>
