---
const year = new Date().getFullYear();

const services = [
  { label: 'Yksilövalmennus', href: '/palvelut/yksilovalmennus' },
  { label: 'Pienryhmävalmennus', href: '/palvelut/pienryhmavalmennus' },
  { label: 'Ulkotreenit', href: '/palvelut/ulkotreenit' },
  { label: 'Treeniohjelmat', href: '/palvelut/treeniohjelma' },
  { label: 'Yrityspalvelut', href: '/palvelut/yrityspalvelut' },
  { label: 'Treenimatkat', href: '/palvelut/treenimatkat' },
];

const company = [
  { label: 'Tietoa Ilonasta', href: '/#ilona' },
  { label: 'Ota yhteyttä', href: '/yhteystiedot' },
];
---

<footer class="bg-charcoal text-white">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 gap-12 md:grid-cols-4">

      <!-- Brand column -->
      <div class="md:col-span-1">
        <a href="/">
          <img
            src="/images/ilofit-logo-pink-sm.webp"
            srcset="/images/ilofit-logo-pink-sm.webp 220w, /images/ilofit-logo-pink.webp 668w"
            sizes="110px"
            alt="IloFit"
            width="110"
            height="44"
            class="h-10 w-auto object-contain mb-4"
          />
        </a>
        <p class="text-sm text-white/60 leading-relaxed mb-6">
          Personal trainer Turku
        </p>
        <div class="flex gap-4">
          <a
            href="https://www.facebook.com/IloFit.Ilona"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center transition-colors hover:bg-pink"
          >
            <!-- Facebook icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a
            href="https://www.instagram.com/ilofit_ilona"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center transition-colors hover:bg-pink"
          >
            <!-- Instagram icon -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div>
        <h3 class="font-display text-lg font-semibold mb-5 text-white">Palvelut</h3>
        <ul class="space-y-3">
          {services.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-white/60 transition-colors hover:text-pink">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="font-display text-lg font-semibold mb-5 text-white">Yritys</h3>
        <ul class="space-y-3">
          {company.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-white/60 transition-colors hover:text-pink">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div>
        <h3 class="font-display text-lg font-semibold mb-5 text-white">Yhteystiedot</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <!-- Phone icon -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13 19.79 19.79 0 0 1 1.62 4.37 2 2 0 0 1 3.59 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6 6l.92-.92a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 17z"/>
            </svg>
            <a href="tel:+358400315775" class="text-sm text-white/60 hover:text-pink transition-colors">
              +358 400 315 775
            </a>
          </li>
          <li class="flex items-start gap-3">
            <!-- Mail icon -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:ilona@ilofit.com" class="text-sm text-white/60 hover:text-pink transition-colors">
              ilona@ilofit.com
            </a>
          </li>
          <li class="flex items-start gap-3">
            <!-- MapPin icon -->
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 flex-shrink-0">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="text-sm text-white/60">Turku & lähialueet</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-white/40">
        © {year} IloFit. Kaikki oikeudet pidätetään.
      </p>
      <a href="/tietosuoja" class="text-xs text-white/40 hover:text-white/70 transition-colors">
        Tietosuoja
      </a>
    </div>
  </div>
</footer>
