---
const pathname = Astro.url.pathname;
const isContactPage = pathname.includes('/yhteystiedot');
---

{!isContactPage && (
  <div id="floating-cta" class="fixed bottom-6 right-6 z-50 opacity-0 scale-90 translate-y-5 pointer-events-none transition-all duration-300">
    <a
      href="/yhteystiedot"
      class="flex items-center gap-2 rounded-full bg-pink px-5 py-3.5 text-sm font-medium text-white shadow-warm-md transition-all duration-200 hover:bg-pink-dark hover:scale-105 active:scale-100"
    >
      <!-- Calendar icon -->
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
      Varaa aika
    </a>
  </div>

  <script>
    const cta = document.getElementById('floating-cta')!;
    window.addEventListener('scroll', () => {
      const visible = window.scrollY > window.innerHeight * 0.8;
      if (visible) {
        cta.classList.remove('opacity-0', 'scale-90', 'translate-y-5', 'pointer-events-none');
        cta.classList.add('opacity-100', 'scale-100', 'translate-y-0');
      } else {
        cta.classList.add('opacity-0', 'scale-90', 'translate-y-5', 'pointer-events-none');
        cta.classList.remove('opacity-100', 'scale-100', 'translate-y-0');
      }
    }, { passive: true });
  </script>
)}
