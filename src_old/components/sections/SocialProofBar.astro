---
---

<div class="bg-off-white border-b border-soft-border">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex flex-wrap items-center justify-center gap-8 py-4 md:justify-between">

      <!-- Google rating -->
      <div class="flex items-center gap-2">
        <div class="flex gap-0.5">
          {[...Array(5)].map(() => (
            <svg width="14" height="14" viewBox="0 0 24 24" fill="#E8A0B0" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            </svg>
          ))}
        </div>
        <span class="text-sm text-charcoal-mid">
          <strong class="text-charcoal">5.0</strong> Google-arvostelua
        </span>
      </div>

      <div class="hidden md:block h-4 w-px bg-soft-border"></div>

      <!-- Certified -->
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/>
        </svg>
        <span class="text-sm text-charcoal-mid">Sertifioitu personal trainer</span>
      </div>

      <div class="hidden md:block h-4 w-px bg-soft-border"></div>

      <!-- Location -->
      <div class="flex items-center gap-2">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#E8A0B0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span class="text-sm text-charcoal-mid">Turku & lähialueet</span>
      </div>

    </div>
  </div>
</div>
